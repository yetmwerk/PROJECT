    {
      "name": "3. Appointments & Scheduling",
      "item": [
        {
          "name": "Create Appointment",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.data && response.data.id) {",
                  "    pm.collectionVariables.set(\"last_appointment_id\", response.data.id);",
                  "    pm.collectionVariables.set(\"last_reference_code\", response.data.reference_code || response.data.referenceCode);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearer_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"visitorId\": 1,\n  \"hostId\": 2,\n  \"scheduledStart\": \"2026-07-08 10:00:00\",\n  \"scheduledEnd\": \"2026-07-08 11:30:00\",\n  \"priority\": \"MEDIUM\",\n  \"purpose\": \"Quarterly business review alignment\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appointments",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments"]
            }
          }
        },
        {
          "name": "Approve Appointment",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearer_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PATCH",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"comment\": \"On-site documentation verified. Host approved.\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/appointments/{{last_appointment_id}}/approve",
              "host": ["{{base_url}}"],
              "path": ["api", "appointments", "{{last_appointment_id}}", "approve"]
            }
          }
        }
      ]
    },
