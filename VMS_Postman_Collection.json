{
  "info": {
    "_postman_id": "8c59f0f9-2b0e-4fae-9fa9-43c2fb1c4cd2",
    "name": "Visitor Management System (VMS) API",
    "description": "Integration testing collection for VMS core endpoints (Auth, Visitors, Appointments, Approvals, Checkin/Checkout, and Dashboards).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Authentication & Session",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Jane Doe\",\n  \"email\": \"jane.doe@email.com\",\n  \"password\": \"Password123!\",\n  \"phone\": \"+1-555-8822\",\n  \"role\": \"visitor\",\n  \"company\": \"Global Tech Corp\",\n  \"idType\": \"Passport\",\n  \"idNumber\": \"PP-9821034\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "if (response && response.token) {",
                  "    pm.collectionVariables.set(\"bearer_token\", response.token);",
                  "    pm.test(\"Token saved successfully\", () => {",
                  "        pm.expect(response.token).to.be.a('string');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@visitor.com\",\n  \"password\": \"Password123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Current Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{bearer_token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            }
          }
        }
      ]
    },
